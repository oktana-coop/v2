{
  "name": "v2",
  "productName": "v2",
  "private": true,
  "description": "A local-first rich text editor with Git-style version control, true privacy, and complete control over your data.",
  "author": {
    "name": "Oktana Lab",
    "email": "team@oktana.dev",
    "url": "https://oktana.dev"
  },
  "version": "0.14.4",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/main/index.js",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "app:dir": "electron-builder --dir --publish=never",
    "package": "electron-builder --publish=never",
    "package:mac": "electron-builder --mac --publish=never",
    "package:win": "electron-builder --win --publish=never",
    "package:linux": "electron-builder --linux --publish=never",
    "build": "electron-vite build --outDir=dist",
    "compile": "tsc",
    "dev": "electron-vite dev -w --outDir=dist",
    "debug": "electron-vite dev -w --outDir=dist -- --inspect=9229",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --max-warnings 100",
    "postinstall": "electron-builder install-app-deps",
    "prebuild": "pnpm run compile",
    "start": "electron-vite preview --outDir=dist",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run ./src",
    "test:watch": "vitest ./src",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:headless": "pnpm run build && HEADLESS=true playwright test",
    "test:e2e:only": "playwright test",
    "test:e2e:only:headless": "HEADLESS=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --headed --debug",
    "test:e2e:report": "playwright show-report e2e-results/html"
  },
  "dependencies": {
    "@automerge/automerge": "^3.1.2",
    "@automerge/automerge-repo": "^2.4.0",
    "@automerge/automerge-repo-network-websocket": "^2.4.0",
    "@automerge/automerge-repo-react-hooks": "^2.4.0",
    "@automerge/automerge-repo-storage-indexeddb": "^2.4.0",
    "@automerge/automerge-repo-storage-nodefs": "^2.4.0",
    "@floating-ui/react": "^0.27.8",
    "@headlessui/react": "^2.2.4",
    "@wasmer/wasi": "^1.2.2",
    "better-sqlite3": "^11.10.0",
    "buffer": "^6.0.3",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "debounce": "^2.2.0",
    "effect": "^3.21.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.4",
    "fast-deep-equal": "^3.1.3",
    "isomorphic-git": "^1.34.2",
    "pagedjs": "^0.4.3",
    "path-browserify": "^1.0.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-highlight": "^0.13.0",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.2",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.10.4",
    "prosemirror-view": "^1.40.1",
    "react": "^18.3.1",
    "react-arborist": "^3.4.3",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.9",
    "react-router": "^7.14.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "shiki": "^3.22.0",
    "uuid": "^11.1.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.9.0",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@octokit/types": "^16.0.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-actions": "^8.6.18",
    "@storybook/addon-console": "^3.0.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/html2pdf.js": "^0.10.0",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@types/wicg-file-system-access": "^2023.10.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "electron": "^38.1.0",
    "electron-builder": "^26.9.0",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^0.11.6",
    "globals": "^16.1.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "storybook": "^8.6.18",
    "storybook-addon-remix-react-router": "^4.0.1",
    "storybook-dark-mode": "^4.0.2",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "type-fest": "^4.41.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "cbor-extract",
      "electron",
      "electron-winstaller",
      "esbuild",
      "storybook-addon-remix-react-router"
    ]
  }
}
